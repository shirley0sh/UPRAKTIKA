<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{{title}}</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            padding: 40px;
            max-width: 600px;
            margin: 0 auto;
            text-align: center;
        }
        .message {
            padding: 20px;
            border: 1px solid #ccc;
            margin-top: 20px;
        }
        a {
            display: inline-block;
            margin-top: 20px;
            color: #000;
        }
    </style>
</head>
<body>
    <h1>{{title}}</h1>
    <div class="message">
        <p>{{message}}</p>
    </div>
    <a href="/">Back to Home</a>
</body>
</html>